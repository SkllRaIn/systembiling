# ─── Домен ────────────────────────────────────────────────────
APP_DOMAIN=домен.ru
MAIL_DOMAIN=домен.ru

# ─── База данных ──────────────────────────────────────────────
POSTGRES_PASSWORD=your_strong_db_password_here

# ─── JWT (обязательно поменяйте!) ────────────────────────────
JWT_SECRET=generate_64_random_chars_here
JWT_REFRESH_SECRET=another_64_random_chars_here

# ─── Первый администратор (создаётся при seed) ────────────────
ADMIN_EMAIL=admin@домен.ru
ADMIN_PASSWORD=your_admin_password_here

# ─── Почта ─────────────────────────────────────────────────────
# Вариант 1: свой mailserver (docker-mailserver в compose)
# Пароль ящика noreply@ — задаётся командой setup email add (см. README)
SMTP_PASS=mailbox_password_here

# Вариант 2: внешний SMTP (Яндекс, Gmail и т.д.) — потребует
# собственной правки переменных SMTP_HOST/SMTP_USER в docker-compose.yml
# для сервиса backend

# ─── Telegram bot (опционально ДЛЯ получение кодов)  ──────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Let's Encrypt SSL ───────────────────────────────────────
# Путь к директории с сертификатами (если уже есть)
LETSENCRYPT_PATH=/etc/letsencrypt
